rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 「枠」コレクション：日付・時刻・空き状況のみ（個人情報なし）
    match /slots/{slotId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if
        request.auth != null
        ||
        (resource.data.status == 'open' && request.resource.data.status == 'booked')
        ||
        (resource.data.status == 'booked' && request.resource.data.status == 'open');
    }

    // 「予約」コレクション：氏名・連絡先など個人情報を含む
    // ドキュメントID = 予約番号（ランダムな英数字6桁）
    match /bookings/{bookingCode} {

      // 予約番号を1件ピンポイントで取得 → 誰でも可
      allow get: if true;

      // コレクション全件の一覧取得 → 先生のログインが必須
      allow list: if request.auth != null;

      // 新規作成（保護者の予約）→ 内容を検証してから許可
      // 【修正】なりすまし・データ汚染対策として、以下を必須チェックする
      //   - name / phone / date / time / slotId が文字列であること
      //   - name は1〜50文字、phone は0〜30文字（過大なデータ送信を防止）
      //   - 紐付け先の slots/{slotId} が実在し、現在 "open" であること
      //     （存在しない枠IDや、すでに予約済みの枠への偽装予約を防止）
      allow create: if
        request.resource.data.keys().hasAll(['slotId','name','phone','date','time'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.slotId is string
        && get(/databases/$(database)/documents/slots/$(request.resource.data.slotId)).data.status == 'open';

      // 削除（キャンセル）→ 予約番号を知っていれば可（合言葉方式のため、誰でも実行可能）
      allow delete: if true;

      allow update: if false;
    }
  }
}
